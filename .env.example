PORT=3000
NODE_ENV=development
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
GOOGLE_AI_API_KEY=your-google-ai-api-key
GEMINI_MODEL=gemini-1.5-flash
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_ACCESS_TOKEN=your-meta-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
MCB_JUICE_PAYMENT_LINK=https://pay.example.com/juice
BLINK_PAYMENT_LINK=https://pay.example.com/blink
SUBSCRIPTION_MONTHLY_PRICE_RS=200
DEFAULT_SUBSCRIPTION_DAYS=30
INTERNAL_ADMIN_API_KEY=change-this-for-server-to-server-payment-confirmation
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_OUTPUT_DIMENSIONS=1536
MCB_JUICE_CALLBACK_TOKEN=optional-shared-token-for-juice-webhook
BLINK_CALLBACK_TOKEN=optional-shared-token-for-blink-webhook
PAYMENT_CALLBACK_BASE_URL=https://your-domain.com
PAYMENT_RETURN_URL=https://your-domain.com/payments/return
PEACH_ENTITY_ID=your-peach-entity-id
PEACH_CHECKOUT_URL=https://secure.peachpayments.com/checkout/initiate
BLINK_PAYLINK_API_URL=https://api.blinkpayment.co.uk/api/paylink/v1/paylinks
PEACH_WEBHOOK_SECRET=optional-peach-webhook-secret
PEACH_WEBHOOK_TOLERANCE_SECONDS=300
OUTBOUND_RETRY_MAX_ATTEMPTS=5
OUTBOUND_RETRY_BASE_DELAY_SECONDS=60
OUTBOUND_RETRY_CRON=*/5 * * * *
TRUST_PROXY=true
ENABLE_SECURITY_HEADERS=true
ADMIN_IP_ALLOWLIST=203.0.113.10/32,198.51.100.0/24
PAYMENT_WEBHOOK_IP_ALLOWLIST=
WHATSAPP_WEBHOOK_IP_ALLOWLIST=
METRICS_IP_ALLOWLIST=
ALERT_OUTBOUND_PENDING_THRESHOLD=25
ALERT_OUTBOUND_FAILED_THRESHOLD=10
ALERT_OPEN_DEAD_LETTER_THRESHOLD=5
ALERT_SECURITY_WARNINGS_THRESHOLD=1
ALERT_AUDIT_ERRORS_THRESHOLD=5
ALERT_INBOUND_DUPLICATE_DELIVERIES_THRESHOLD=10
ALERT_EVALUATION_CRON=*/5 * * * *
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_NOTIFY_ON_RESOLVE=false
