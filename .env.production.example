# Mauri production environment template
# Copy to Render (or your host) secrets. Do not commit real values.

NODE_ENV=production
PORT=3000

# Core platform
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
GOOGLE_AI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
INTERNAL_ADMIN_API_KEY=

# Public service URL (Render service URL, custom domain, etc.)
PAYMENT_CALLBACK_BASE_URL=https://mauri-backend.onrender.com
PAYMENT_RETURN_URL=https://mauri-backend.onrender.com/payments/return

# MCB Juice via Peach Payments
PEACH_ENTITY_ID=
PEACH_CHECKOUT_SECRET=
PEACH_CHECKOUT_URL=https://secure.peachpayments.com/checkout/initiate
PEACH_WEBHOOK_SECRET=
PEACH_WEBHOOK_TOLERANCE_SECONDS=300
MCB_JUICE_CALLBACK_TOKEN=
MCB_JUICE_PAYMENT_LINK=

# Blink paylinks
BLINK_API_KEY=
BLINK_SECRET_KEY=
BLINK_TOKEN_API_URL=https://api.blinkpayment.co.uk/api/pay/v1/tokens
BLINK_PAYLINK_API_URL=https://api.blinkpayment.co.uk/api/paylink/v1/paylinks
BLINK_CALLBACK_TOKEN=
BLINK_PAYMENT_LINK=

# Subscription defaults
SUBSCRIPTION_MONTHLY_PRICE_RS=200
DEFAULT_SUBSCRIPTION_DAYS=30

# Security / networking
TRUST_PROXY=true
ENABLE_SECURITY_HEADERS=true
ADMIN_IP_ALLOWLIST=
PAYMENT_WEBHOOK_IP_ALLOWLIST=
WHATSAPP_WEBHOOK_IP_ALLOWLIST=
METRICS_IP_ALLOWLIST=

# Ops
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_NOTIFY_ON_RESOLVE=false
OUTBOUND_RETRY_MAX_ATTEMPTS=5
OUTBOUND_RETRY_BASE_DELAY_SECONDS=60
OUTBOUND_RETRY_CRON=*/5 * * * *
ALERT_EVALUATION_CRON=*/5 * * * *

# Quantum pick (optional ANU QRNG API key)
QUANTUM_PICK_ENABLED=true
ANU_QUANTUM_API_KEY=
ANU_QUANTUM_API_URL=https://api.quantumnumbers.anu.edu.au
QUANTUM_REQUEST_TIMEOUT_MS=2500
